{
  "manifest_version": 3,
  "name": "AI Chat Archiver",
  "version": "1.0.0",
  "description": "一键保存 AI 对话到本地",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://chat.deepseek.com/*",
    "https://poe.com/*",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon48.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content_scripts/base_extractor.js", "content_scripts/chatgpt.js"]
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content_scripts/base_extractor.js", "content_scripts/claude.js"]
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content_scripts/base_extractor.js", "content_scripts/gemini.js"]
    },
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["content_scripts/base_extractor.js", "content_scripts/deepseek.js"]
    },
    {
      "matches": ["https://poe.com/*"],
      "js": ["content_scripts/base_extractor.js", "content_scripts/poe.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
