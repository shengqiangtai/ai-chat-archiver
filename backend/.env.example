# ── 复制此文件为 .env.local 并按需修改 ─────────────────────────────────
# cp backend/.env.example backend/.env.local

# 聊天记录存储目录（默认为项目根目录下的 AI-Chats/）
# ARCHIVER_STORAGE_ROOT=/path/to/your/AI-Chats

# 服务端口（默认 8765）
# ARCHIVER_PORT=8765

# ── 模型路径（运行 download_models.py 后自动填充，也可手动指定）──────────
# 留空则自动查找 models/<模型名> 目录
# EMBEDDING_MODEL=/absolute/path/to/models/Qwen3-Embedding-0.6B
# RERANKER_MODEL=/absolute/path/to/models/Qwen3-Reranker-0.6B
# GENERATOR_MODEL=/absolute/path/to/models/Qwen3.5-0.8B

# ── LM Studio（推荐 Mac 用户）────────────────────────────────────────────
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LMSTUDIO_MODEL=                    # 留空=使用当前加载的模型

# ── 检索参数（低内存设备可适当调小）─────────────────────────────────────
# RETRIEVAL_TOP_K=10
# RERANK_TOP_N=4
# CHUNK_TARGET_SIZE=500

# ── 内存优化 ─────────────────────────────────────────────────────────────
# LOW_MEMORY_MODE=1                  # 强制开启低内存模式
# UNLOAD_GENERATOR_AFTER_INFERENCE=1 # 推理后立即卸载生成模型
